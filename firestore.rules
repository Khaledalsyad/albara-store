rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "khaledalsyad203@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidProduct(data) {
        return data.nameAr is string && data.nameAr.size() < 200 &&
               data.nameEn is string && data.nameEn.size() < 200 &&
               data.basePrice is number && data.basePrice >= 0;
      }
    }

    // Orders
    match /orders/{orderId} {
      allow create: if true; // Customers can create orders
      allow read, update, delete: if isAdmin();
      
      function isValidOrder(data) {
        return data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.status in ["pending", "processing", "shipped", "delivered"];
      }
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
