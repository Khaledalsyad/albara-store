{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Coffee product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "descriptionAr": { "type": "string" },
        "descriptionEn": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "basePrice": { "type": "number" },
        "weights": { "type": "array" }
      },
      "required": ["id", "nameAr", "nameEn", "basePrice"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Store-wide configuration",
      "type": "object",
      "properties": {
        "announcementAr": { "type": "string" },
        "announcementEn": { "type": "string" },
        "whatsappNumber": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Coffee products collection"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders collection"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "App settings"
    }
  }
}
